<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:formatter="com.gambit.evaforecast.model.formatter">
    <TableSelectDialog id="projectValueHelpDialog" 
                  title="{local>/vhTitle}" 
                  multiSelect="false" 
                  rememberSelections="false" 
                  contentWidth="80rem"
                  updateFinished="onVHUpdateFinished"
                  confirm="onProjectVHConfirm" 
                  cancel="onProjectVHCancel"
                  search="onProjectVHSearch"
                  items="{
                      path: '/ZI_CustomerProjectVH',
                      length: 10000,
                      parameters: {
                          select: 'ProjectUUID,Project,ProjectDescription,EntProjectIsConfidential,ParentProject,ParentProjectDescription,cntInProgress,cntTeamMember'
                      }
                  }">
        <columns>
            <Column><header><Label text="{i18n>projectCol}" /></header></Column>
            <Column><header><Label text="{i18n>projectDescCol}" /></header></Column>
            <Column demandPopin="true" minScreenWidth="Tablet"><header><Label text="{i18n>projectIsConfidentialCol}" /></header></Column>
            <Column demandPopin="true" minScreenWidth="Tablet"><header><Label text="{i18n>projectParentCol}" /></header></Column>
            <Column demandPopin="true" minScreenWidth="Desktop"><header><Label text="{i18n>projectParentDescCol}" /></header></Column>
            <Column demandPopin="true" minScreenWidth="Desktop"><header><Label text="{i18n>projectCntInProgressCol}" /></header></Column>
            <Column demandPopin="true" minScreenWidth="Desktop"><header><Label text="{i18n>projectCntTeamMemberCol}" /></header></Column>
        </columns>
        <ColumnListItem>
            <customData>
                <core:CustomData key="uuid" value="{ProjectUUID}" />
            </customData>
            <cells>
                <Text text="{Project}" />
                <Text text="{ProjectDescription}" />
                <Text text="{
                    path: 'EntProjectIsConfidential',
                    formatter: '.formatter.booleanToYesNo'
                }" />
                <Text text="{ParentProject}" />
                <Text text="{ParentProjectDescription}" />
                <Text text="{cntInProgress}" />
                <Text text="{cntTeamMember}" />
            </cells>
        </ColumnListItem>
    </TableSelectDialog>
</core:FragmentDefinition>